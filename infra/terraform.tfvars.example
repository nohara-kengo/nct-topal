aws_region = "ap-northeast-1"
project    = "topal"
env        = "dev" # dev or prd

# 日次レポート対象プロジェクト（カンマ区切りで複数指定可能）
report_project_keys = "NOHARATEST"

# 日次レポートスケジュール（UTC cron式、デフォルト: JST 8:00 + 15:00 平日）
# report_schedules = {
#   morning   = "cron(0 23 ? * SUN-THU *)"
#   afternoon = "cron(0 6 ? * MON-FRI *)"
# }

# --- SSM パラメータ初期値 ---
# シークレット値は初回apply時のみ使用（以降はignore_changesで無視）
# 実際の値はCIシークレットまたは -var で渡す

# claude_model         = "claude-haiku-4-5-20251001"
# anthropic_api_key    = "sk-ant-..."
# slack_signing_secret = "..."
# slack_bot_token      = "xoxb-..."
# microsoft_app_id     = "..."
# microsoft_app_password = "..."

# Backlog（プロジェクトキーごと）
# backlog_api_keys = {
#   NOHARATEST = "..."
# }
# backlog_space_urls = {
#   NOHARATEST = "https://comthink06.backlog.com"
# }
