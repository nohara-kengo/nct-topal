# dev環境のシークレット（GitHub Environment Secrets から CI/CD で自動生成される）
# 手動で作成する必要はない。GitHub の dev 環境に以下の Secrets を登録すること。
#
# GitHub → Settings → Environments → dev → Environment secrets:
#   ANTHROPIC_API_KEY      = "sk-ant-api03-..."
#   SLACK_SIGNING_SECRET   = "..."
#   SLACK_BOT_TOKEN        = "xoxb-..."
#   MICROSOFT_APP_ID       = "..."
#   MICROSOFT_APP_PASSWORD = "..."
#   BACKLOG_API_KEYS       = {"NOHARATEST":"..."}  ← JSON形式
#
# プロジェクト追加時は BACKLOG_API_KEYS の JSON にキーを追加:
#   {"NOHARATEST":"...", "NEWPROJECT":"..."}
